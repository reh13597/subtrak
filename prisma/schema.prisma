generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  cognitoId     String         @unique @db.VarChar(255)
  email         String         @unique @db.VarChar(255)
  firstName     String?        @db.VarChar(100)
  lastName      String?        @db.VarChar(100)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
  uploads       StatementUpload[]
}

enum BillingCycle {
  MONTHLY
  YEARLY
  WEEKLY
  CUSTOM
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model Subscription {
  id              Int                @id @default(autoincrement())
  userId          Int
  name            String             @db.VarChar(200)
  price           Decimal            @db.Decimal(10, 2)
  currency        String             @default("CAD") @db.VarChar(3)
  billingCycle    BillingCycle       @default(MONTHLY)
  status          SubscriptionStatus @default(ACTIVE)
  category        String?            @db.VarChar(100)
  providerUrl     String?            @db.VarChar(500)
  nextBillingDate DateTime?
  notes           String?            @db.Text
  icon            String?            @db.VarChar(500)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UploadStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model StatementUpload {
  id           Int            @id @default(autoincrement())
  userId       Int
  fileName     String         @db.VarChar(500)
  fileData     Bytes?         @db.LongBlob
  mimeType     String?        @db.VarChar(100)
  status       UploadStatus   @default(PENDING)
  createdAt    DateTime       @default(now())
  extractions  ExtractedSubscription[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum ReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ExtractedSubscription {
  id              Int          @id @default(autoincrement())
  uploadId        Int
  name            String       @db.VarChar(200)
  price           Decimal      @db.Decimal(10, 2)
  currency        String       @default("CAD") @db.VarChar(3)
  billingCycle    BillingCycle @default(MONTHLY)
  providerUrl     String?      @db.VarChar(500)
  lastChargeDate  DateTime?
  nextBillingDate DateTime?
  confidenceScore Float        @default(0)
  reviewStatus    ReviewStatus @default(PENDING)
  rawJson         Json?
  createdAt       DateTime     @default(now())

  upload StatementUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
}
